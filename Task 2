	JMP start
data:
	DB 10, 20, 30, 15, 25
len:
	DB 5
start:
	MOV A, 0      ; сумма
	MOV B, data   ; указатель
	MOV C, [len]  ; счётчик
    
loop:
    ADD A, [B]
    INC B
    DEC C
    JNZ loop

prepare:
    MOV B, 0
    MOV C, 0
    MOV B, A
digit:
    INC C
    DIV 10
    JNZ digit
    ADD C, 231
    MOV A, B
print:
	DIV 10
	MUL 10
	SUB B, A
	ADD B, 48
	MOV [C], B
    DIV 10
	MOV B, A
	DEC C
	CMP C, 231
	JNZ print

HLT
